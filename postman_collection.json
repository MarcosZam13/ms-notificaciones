{
  "info": {
    "name": "Microservicio de Notificaciones",
    "description": "API REST para gestión de notificaciones asíncronas de la plataforma de arrendamientos. Autenticación vía JWT (Bearer token).\n\nWebSocket documentado en README.md",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "notificaciones-svc"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{jwt_token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://ms-notificaciones.azurewebsites.net",
      "type": "string",
      "description": "Producción Azure. Para local usar http://localhost:8000"
    },
    {
      "key": "jwt_token",
      "value": "PEGAR_TOKEN_JWT_AQUI",
      "type": "string",
      "description": "Token JWT HS256 obtenido del MS Usuarios (/auth/login). Pegar el valor del campo 'token' de la respuesta."
    },
    {
      "key": "usuario_id",
      "value": "usuario-123",
      "type": "string",
      "description": "ID del usuario autenticado — debe coincidir con el 'sub' del JWT"
    },
    {
      "key": "notificacion_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "fcm_token",
      "value": "dummy-fcm-token-abc123",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Sistema",
      "item": [
        {
          "name": "Health Check",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Test: Verificar que el servicio responde saludable",
                  "pm.test('Status code es 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Respuesta contiene status healthy', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.status).to.eql('healthy');",
                  "    pm.expect(jsonData.service).to.eql('notificaciones');",
                  "});",
                  "",
                  "pm.test('Respuesta tiene campos de métricas', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('ws_connections');",
                  "    pm.expect(jsonData).to.have.property('ws_users');",
                  "    pm.expect(jsonData.ws_connections).to.be.a('number');",
                  "    pm.expect(jsonData.ws_users).to.be.a('number');",
                  "});",
                  "",
                  "pm.test('Tiempo de respuesta menor a 500ms', function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(500);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/health",
              "host": ["{{base_url}}"],
              "path": ["health"]
            },
            "description": "Verifica el estado de salud del microservicio. No requiere autenticación."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Notificaciones",
      "item": [
        {
          "name": "Listar notificaciones (paginado)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Test: Listar notificaciones paginadas",
                  "pm.test('Status code 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Respuesta tiene estructura paginada', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('items');",
                  "    pm.expect(jsonData).to.have.property('total');",
                  "    pm.expect(jsonData).to.have.property('pagina');",
                  "    pm.expect(jsonData).to.have.property('tamano_pagina');",
                  "    pm.expect(jsonData).to.have.property('total_paginas');",
                  "    pm.expect(jsonData.items).to.be.an('array');",
                  "});",
                  "",
                  "pm.test('Total y total_paginas son números válidos', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.total).to.be.a('number');",
                  "    pm.expect(jsonData.total_paginas).to.be.a('number');",
                  "    pm.expect(jsonData.pagina).to.eql(1);",
                  "});",
                  "",
                  "// Guardar ID de la primera notificación para tests posteriores",
                  "var jsonData = pm.response.json();",
                  "if (jsonData.items.length > 0) {",
                  "    pm.collectionVariables.set('notificacion_id', jsonData.items[0].id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/notificaciones/{{usuario_id}}?pagina=1&tamano=20",
              "host": ["{{base_url}}"],
              "path": ["notificaciones", "{{usuario_id}}"],
              "query": [
                { "key": "pagina", "value": "1" },
                { "key": "tamano", "value": "20" }
              ]
            },
            "description": "Obtiene las notificaciones del usuario de forma paginada, ordenadas por fecha descendente (más recientes primero)."
          },
          "response": []
        },
        {
          "name": "Listar notificaciones - Página 3",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Test: Verificar paginación en página 3",
                  "pm.test('Status code 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Página es 3', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.pagina).to.eql(3);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/notificaciones/{{usuario_id}}?pagina=3&tamano=5",
              "host": ["{{base_url}}"],
              "path": ["notificaciones", "{{usuario_id}}"],
              "query": [
                { "key": "pagina", "value": "3" },
                { "key": "tamano", "value": "5" }
              ]
            },
            "description": "Lista notificaciones de la página 3 con 5 items por página. Verifica que la paginación funciona correctamente."
          },
          "response": []
        },
        {
          "name": "Listar notificaciones - Sin token (401)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Test: Verificar que devuelve 401 sin token",
                  "pm.test('Status code 401 sin token', function () {",
                  "    pm.response.to.have.status(401);",
                  "});",
                  "",
                  "pm.test('Detalle indica token requerido', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.detail).to.include('Not authenticated');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/notificaciones/{{usuario_id}}",
              "host": ["{{base_url}}"],
              "path": ["notificaciones", "{{usuario_id}}"]
            },
            "description": "Verifica que el endpoint requiere autenticación JWT. Debe retornar 401 sin token."
          },
          "response": []
        },
        {
          "name": "Conteo de no leídas",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Test: Conteo de notificaciones no leídas",
                  "pm.test('Status code 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Respuesta tiene campos correctos', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('usuario_id');",
                  "    pm.expect(jsonData).to.have.property('no_leidas');",
                  "    pm.expect(jsonData.usuario_id).to.eql(pm.collectionVariables.get('usuario_id'));",
                  "    pm.expect(jsonData.no_leidas).to.be.a('number');",
                  "    pm.expect(jsonData.no_leidas).to.be.at.least(0);",
                  "});",
                  "",
                  "pm.test('Tiempo de respuesta menor a 1s', function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(1000);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/notificaciones/{{usuario_id}}/no-leidas",
              "host": ["{{base_url}}"],
              "path": ["notificaciones", "{{usuario_id}}", "no-leidas"]
            },
            "description": "Retorna el conteo total de notificaciones no leídas del usuario."
          },
          "response": []
        },
        {
          "name": "Marcar notificación como leída",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Test: Marcar notificación como leída",
                  "var notifId = pm.collectionVariables.get('notificacion_id');",
                  "",
                  "if (!notifId || notifId === '') {",
                  "    pm.test('Sin notificación para marcar - se omite test', function () {",
                  "        pm.expect(true).to.be.true;",
                  "    });",
                  "} else {",
                  "    pm.test('Status code 200', function () {",
                  "        pm.response.to.have.status(200);",
                  "    });",
                  "",
                  "    pm.test('Mensaje de confirmación', function () {",
                  "        var jsonData = pm.response.json();",
                  "        pm.expect(jsonData.mensaje).to.include('marcada como leída');",
                  "        pm.expect(jsonData.id).to.eql(notifId);",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/notificaciones/{{notificacion_id}}/leer",
              "host": ["{{base_url}}"],
              "path": ["notificaciones", "{{notificacion_id}}", "leer"]
            },
            "description": "Marca una notificación específica como leída. Cambia el estado 'leida' de false a true."
          },
          "response": []
        },
        {
          "name": "Marcar como leída - ID inexistente (404)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Test: Marcar notificación inexistente debe dar 404",
                  "pm.test('Status code 404 para ID inexistente', function () {",
                  "    pm.response.to.have.status(404);",
                  "});",
                  "",
                  "pm.test('Detalle indica no encontrada', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.detail).to.include('no encontrada');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/notificaciones/000000000000000000000000/leer",
              "host": ["{{base_url}}"],
              "path": ["notificaciones", "000000000000000000000000", "leer"]
            },
            "description": "Intenta marcar una notificación con un ID MongoDB inválido. Debe retornar 404."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Dispositivos",
      "item": [
        {
          "name": "Registrar dispositivo FCM",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Test: Registrar dispositivo para push notifications",
                  "pm.test('Status code 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Respuesta tiene datos del dispositivo', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('usuario_id');",
                  "    pm.expect(jsonData).to.have.property('fcm_token');",
                  "    pm.expect(jsonData).to.have.property('plataforma');",
                  "    pm.expect(jsonData).to.have.property('actualizado_en');",
                  "});",
                  "",
                  "pm.test('Plataforma es la enviada', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.plataforma).to.eql('android');",
                  "});",
                  "",
                  "pm.test('usuario_id coincide con el enviado', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.usuario_id).to.eql(pm.collectionVariables.get('usuario_id'));",
                  "});",
                  "",
                  "pm.test('actualizado_en es una fecha ISO', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.actualizado_en).to.match(/\\d{4}-\\d{2}-\\d{2}T/);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"usuario_id\": \"{{usuario_id}}\",\n  \"fcm_token\": \"{{fcm_token}}\",\n  \"plataforma\": \"android\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/dispositivos/dispositivo",
              "host": ["{{base_url}}"],
              "path": ["dispositivos", "dispositivo"]
            },
            "description": "Registra o actualiza el token FCM de un dispositivo para recibir notificaciones push. Si el usuario ya tiene un token registrado, se sobrescribe."
          },
          "response": []
        },
        {
          "name": "Registrar dispositivo - Sin token (401)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Test: Verificar que requiere autenticación",
                  "pm.test('Status code 401 sin token', function () {",
                  "    pm.response.to.have.status(401);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"usuario_id\": \"usuario-123\",\n  \"fcm_token\": \"token-sin-auth\",\n  \"plataforma\": \"web\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/dispositivos/dispositivo",
              "host": ["{{base_url}}"],
              "path": ["dispositivos", "dispositivo"]
            },
            "description": "Verifica que el endpoint de dispositivos también requiere autenticación JWT."
          },
          "response": []
        },
        {
          "name": "Registrar dispositivo - plataforma iOS",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Test: Registrar dispositivo iOS",
                  "pm.test('Status code 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Plataforma es iOS', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.plataforma).to.eql('ios');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"usuario_id\": \"{{usuario_id}}\",\n  \"fcm_token\": \"ios-fcm-token-xyz789\",\n  \"plataforma\": \"ios\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/dispositivos/dispositivo",
              "host": ["{{base_url}}"],
              "path": ["dispositivos", "dispositivo"]
            },
            "description": "Registra un dispositivo iOS. Verifica que se aceptan diferentes plataformas."
          },
          "response": []
        },
        {
          "name": "Registrar dispositivo - Datos inválidos (422)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Test: Validar que rechaza datos inválidos",
                  "pm.test('Status code 422 para datos inválidos', function () {",
                  "    pm.response.to.have.status(422);",
                  "});",
                  "",
                  "pm.test('Respuesta contiene detalle de error', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('detail');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"plataforma\": \"android\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/dispositivos/dispositivo",
              "host": ["{{base_url}}"],
              "path": ["dispositivos", "dispositivo"]
            },
            "description": "Envía datos incompletos (faltan usuario_id y fcm_token). Debe retornar 422 Unprocessable Entity por validación de Pydantic."
          },
          "response": []
        }
      ]
    }
  ]
}
